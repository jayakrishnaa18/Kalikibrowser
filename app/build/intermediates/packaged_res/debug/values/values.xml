<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#4285F4</color>
    <color name="accent_dark">#1A73E8</color>
    <color name="accent_light">#E8F0FE</color>
    <color name="bg_hover">#E8EAED</color>
    <color name="bg_primary">#FFFFFF</color>
    <color name="bg_secondary">#F8F9FA</color>
    <color name="bg_tertiary">#F1F3F4</color>
    <color name="black">#000000</color>
    <color name="border">#DADCE0</color>
    <color name="card_bg">#FFFFFF</color>
    <color name="danger">#EA4335</color>
    <color name="dark_bg_primary">#202124</color>
    <color name="dark_bg_secondary">#292A2D</color>
    <color name="dark_bg_tertiary">#35363A</color>
    <color name="dark_border">#3C4043</color>
    <color name="dark_card_bg">#292A2D</color>
    <color name="dark_text_primary">#E8EAED</color>
    <color name="dark_text_secondary">#9AA0A6</color>
    <color name="dark_url_bar_bg">#35363A</color>
    <color name="orange">#FA7B17</color>
    <color name="shield_green">#34A853</color>
    <color name="success">#34A853</color>
    <color name="text_hint">#9AA0A6</color>
    <color name="text_primary">#202124</color>
    <color name="text_secondary">#5F6368</color>
    <color name="toolbar_bg">#FFFFFF</color>
    <color name="url_bar_bg">#F1F3F4</color>
    <color name="warning">#FBBC04</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">Kaliki Browser</string>
    <string name="search_hint">Search or enter URL...</string>
    <style name="BottomSheetShape" parent="">
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>
    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShape</item>
    </style>
    <style name="BottomSheetTheme" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:colorBackground">@android:color/transparent</item>
    </style>
    <style name="MenuIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>
    <style name="MenuItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">14dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>
    <style name="MenuLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:maxLines">1</item>
    </style>
    <style name="Theme.KalikiBrowser" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/toolbar_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="Theme.KalikiBrowser.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:colorBackground">@color/dark_bg_primary</item>
        <item name="colorSurface">@color/dark_bg_secondary</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>