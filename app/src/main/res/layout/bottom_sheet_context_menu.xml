<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/handle_bg"
        android:layout_marginBottom="12dp" />

    <!-- URL preview -->
    <TextView
        android:id="@+id/context_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Open in new tab -->
    <LinearLayout
        android:id="@+id/ctx_open_new_tab"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_add" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Open in new tab" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Save / Download -->
    <LinearLayout
        android:id="@+id/ctx_save"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_download" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:id="@+id/ctx_save_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Save image" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Copy URL -->
    <LinearLayout
        android:id="@+id/ctx_copy"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Copy URL" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Share -->
    <LinearLayout
        android:id="@+id/ctx_share"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_share" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Share" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>
</LinearLayout>
