<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingBottom="12dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/handle_bg"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />

    <!-- Quick Actions: 4 icons in a row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="6dp">

        <LinearLayout android:id="@+id/menu_new_tab" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_add" style="@style/MenuIcon" app:tint="@color/accent" />
            <TextView android:text="New tab" style="@style/MenuLabel" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_incognito_top" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_incognito" style="@style/MenuIcon" app:tint="#CE93D8" />
            <TextView android:text="Private" style="@style/MenuLabel" android:textColor="#CE93D8" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_add_bookmark" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_bookmark" style="@style/MenuIcon" app:tint="@color/warning" />
            <TextView android:text="Bookmark" style="@style/MenuLabel" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_share" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_share" style="@style/MenuIcon" app:tint="@color/text_secondary" />
            <TextView android:text="Share" style="@style/MenuLabel" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="6dp" />

    <!-- Menu items -->
    <LinearLayout android:id="@+id/menu_bookmarks" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_bookmark" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bookmarks" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_history" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_history" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_downloads" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_download" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Downloads" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="6dp" />

    <LinearLayout android:id="@+id/menu_find" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_search" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find in page" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_desktop" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_desktop" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Desktop site" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_translate" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_share" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Translate" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="6dp" />

    <LinearLayout android:id="@+id/menu_add_home" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_add" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add to home screen" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/menu_settings" android:layout_width="match_parent" android:layout_height="46dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_settings" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="15sp" android:textColor="@color/text_primary" />
    </LinearLayout>
</LinearLayout>
