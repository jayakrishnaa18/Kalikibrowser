<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/handle_bg"
        android:layout_marginBottom="16dp" />

    <!-- Quick Actions Row: New Tab | Incognito | Bookmark | Share -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout android:id="@+id/menu_new_tab" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_add" style="@style/MenuIcon" app:tint="@color/accent" />
            <TextView android:text="New Tab" style="@style/MenuLabel" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_incognito_top" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_incognito" style="@style/MenuIcon" app:tint="@color/text_primary" />
            <TextView android:text="Incognito" style="@style/MenuLabel" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_add_bookmark" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_bookmark" style="@style/MenuIcon" app:tint="@color/warning" />
            <TextView android:text="Bookmark" style="@style/MenuLabel" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menu_share" style="@style/MenuItem">
            <ImageView android:src="@drawable/ic_share" style="@style/MenuIcon" app:tint="@color/text_primary" />
            <TextView android:text="Share" style="@style/MenuLabel" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="8dp" />

    <!-- List Options -->
    <LinearLayout
        android:id="@+id/menu_bookmarks"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bookmark" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bookmarks" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_history"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_history" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_downloads"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_download" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Downloads" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="8dp" />

    <LinearLayout
        android:id="@+id/menu_find"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find in page" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_desktop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_desktop" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Desktop site" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_incognito_toggle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_incognito" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Incognito mode" android:textSize="14sp" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/menu_incognito_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/accent" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_reader"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_reader" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reader mode" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="8dp" />

    <LinearLayout
        android:id="@+id/menu_print"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_print" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Print" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_add_home"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_add" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add to home screen" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_translate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_share" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Translate page" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_qr_code"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QR Code" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_screenshot"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_download" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Screenshot page" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_video_download"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_download" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Download video" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginHorizontal="16dp" android:layout_marginVertical="8dp" />

    <LinearLayout
        android:id="@+id/menu_settings"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_settings" app:tint="@color/text_secondary" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="14sp" android:textColor="@color/text_primary" />
    </LinearLayout>
</LinearLayout>
