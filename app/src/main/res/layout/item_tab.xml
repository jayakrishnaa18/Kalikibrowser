<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border"
    app:cardBackgroundColor="@color/bg_tertiary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Tab header: favicon + title + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@color/bg_secondary">

            <ImageView
                android:id="@+id/tab_favicon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_logo"
                android:layout_marginEnd="10dp"
                app:tint="@color/accent" />

            <TextView
                android:id="@+id/tab_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/tab_close_btn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                app:tint="@color/text_hint" />
        </LinearLayout>

        <!-- Tab thumbnail preview -->
        <ImageView
            android:id="@+id/tab_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="@color/bg_secondary"
            android:visibility="gone" />

        <!-- Tab content preview area (URL as fallback) -->
        <LinearLayout
            android:id="@+id/tab_url_container"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tab_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
