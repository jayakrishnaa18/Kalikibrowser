<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg_primary"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="What interests you?"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose topics for your Discover feed (at least 3)"
        android:textSize="15sp"
        android:textColor="@color/dark_text_secondary"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Language Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:background="@drawable/url_bar_bg"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="News language"
            android:textSize="15sp"
            android:textColor="@color/text_primary" />

        <Spinner
            android:id="@+id/language_spinner"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="140dp"
            android:background="@drawable/shortcut_bg"
            android:paddingHorizontal="12dp" />
    </LinearLayout>

    <!-- Scrollable grid of interest chips -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="true">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/interests_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

    </ScrollView>

    <!-- Selection count indicator -->
    <TextView
        android:id="@+id/selection_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 selected — pick at least 3"
        android:textSize="13sp"
        android:textColor="@color/dark_text_secondary"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <!-- Continue button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        android:layout_marginBottom="16dp"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/accent" />

</LinearLayout>
