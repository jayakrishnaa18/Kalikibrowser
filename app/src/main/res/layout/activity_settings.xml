<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="@color/bg_secondary">

        <ImageButton
            android:id="@+id/btn_back_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Privacy Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRIVACY &amp; SECURITY"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_adblock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Ad Blocker"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_tracker"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Tracker Blocker"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_cookies"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Block Third-Party Cookies"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_dnt"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Do Not Track"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <!-- Display Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISPLAY"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_dark_mode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Force Dark Mode on Pages"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_javascript"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="JavaScript"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_images"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Load Images"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_save_data"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Data Saver Mode"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent"
                app:trackTint="@color/bg_tertiary" />

            <!-- Search Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEARCH ENGINE"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_search_engine"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/url_bar_bg"
                android:padding="8dp" />

            <!-- Clear Data Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLEAR DATA"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_clear_cache"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Clear Cache"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_tertiary"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_clear_cookies"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Clear Cookies"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_tertiary"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_clear_all"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Clear All Browsing Data"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/accent" />

            <!-- About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/version_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kaliki Browser v1.0.0"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
